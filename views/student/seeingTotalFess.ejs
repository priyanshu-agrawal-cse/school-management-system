<% layout("/layouts/boilerplate") %>

    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #f8f9fa;
        }

        #sidebar {
            background-color: #1e1e1e;
            border-right: 1px solid #2c2c2c;
            height: 100vh;
        }

        #sidebar h2 {
            font-weight: bold;
            padding-top: 1rem;
            padding-left: 1rem;
            height: 1rem;
            margin-bottom: 30px;
            color: #fff;
        }

        .nav-item a div {
            color: white;
        }

        #sidebar ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        #sidebar .nav-link {
            display: flex;
            align-items: center;
            padding: 0.8rem 1rem;
            border-radius: 0.5rem;
            color: #ccc;
            text-decoration: none;
            transition: background 0.2s, color 0.2s;
        }

        #sidebar .nav-link:hover,
        #sidebar .nav-link.active {
            background-color: #2c5234;
            color: #fff;
        }

        #sidebar .nav-link i {
            margin-right: 10px;
        }

        .main-content {
            flex-grow: 1;
            padding: 30px;
            background-color: #fff;
            min-height: 100vh;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-green {
            background-color: #2c5234;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
        }

        .filters {
            display: flex;
            gap: 15px;
            margin: 20px 0;
            align-items: center;
            flex-wrap: wrap;
        }

        .filters input,
        .filters select {
            padding: 6px 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 8px;
            overflow: hidden;
        }

        table th,
        table td {
            padding: 12px;
            border-bottom: 1px solid #eee;
            text-align: left;
            font-size: 14px;
        }

        table th {
            background: #f1f1f1;
            font-weight: 600;
        }

        .status-link {
            color: #2c5234;
            font-weight: bold;
            cursor: pointer;
        }
    </style>

    <div class="d-flex">
        <!-- Sidebar -->
        <div id="sidebar" class="p-3" style="width: 18rem">
            <h2>Alter</h2>
            <ul class="nav flex-column mt-2">
                <li class="nav-item">
                    <a href="/dashboard" class="nav-link mt-4">
                        <div><i class="bi bi-speedometer2"></i> Dashboard</div>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/students" class="nav-link">
                        <div><i class="bi bi-people"></i> Students</div>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/fees" class="nav-link active">
                        <div><i class="bi bi-cash-stack"></i> Fees</div>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/account" class="nav-link">
                        <div><i class="bi bi-person-circle"></i> Account Details</div>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/billing" class="nav-link">
                        <div><i class="bi bi-receipt"></i> Billing</div>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/settings" class="nav-link">
                        <div><i class="bi bi-gear"></i> Settings</div>
                    </a>
                </li>
            </ul>
        </div>

        <!-- Right Panel -->
        <div class="main-content">
            <!-- Top bar -->
            <div class="top-bar">
                <div>
                    <h2>Fees</h2>
                    <p>Manage and monitor Student fees payment.</p>
                </div>
                <form action="/verify-bank-statement" method="POST" enctype="multipart/form-data"
                    style="display:flex; flex-direction:column; gap:10px; max-width:250px;">
                    <input type="file" name="bankStatement" id="fileUpload" accept=".pdf" required>
                    <button type="submit" class="btn-green">Verify Bank Statement</button>
                </form>
            </div>
            <small>Upload Bank Statement PDF to verify transactions</small>

            <!-- Filters -->
            <div class="filters">
                <input type="text" placeholder="Search by Name">
                <select>
                    <option>Type</option>
                    <option>Days</option>
                    <option>Months</option>
                </select>
                <select>
                    <option>Class</option>
                    <% school.classId.forEach(c=> { %>
                        <option value="<%= c._id %>">
                            <%= c.class %> (<%= c.section %>)
                        </option>
                        <% }) %>
                </select>
                <select>
                    <option>Months</option>
                    <option>June</option>
                    <option>July</option>
                </select>
                <select>
                    <option>Status</option>
                    <option>Paid</option>
                    <option>Pending</option>
                </select>
            </div>

            <!-- Table -->
           <!-- Table -->
<table>
    <thead>
        <tr>
            <th>S/1</th>
            <th>Name</th>
            <th>Class</th>
            <th>Tran no</th>
            <th>Fees</th>
            <th>Tran Time/Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        <% if (transactions && transactions.length > 0) { %>
            <% transactions.forEach((t, index) => { %>
                <tr>
                    <td><%= index + 1 %>.</td>
                    <td><%= t.studentId ? t.studentId.name : "N/A" %></td>
                    <td>
                        <% if (t.studentId && t.studentId.classId) { %>
                            <%= t.studentId.classId.class %> (<%= t.studentId.classId.section %>)
                        <% } else { %>
                            N/A
                        <% } %>
                    </td>
                    <td><%= t.UTR ? t.UTR : "Cash" %></td>
                    <td><%= t.amount %></td>
                    <td>
                        <% if (t.date) { %>
                            <%= new Date(t.date).toLocaleDateString() %>
                            <%= new Date(t.date).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                    <td>
                        <span class="status-link">
                            <%= t.status || "Activate" %>
                        </span>
                    </td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="7" style="text-align:center;">No transactions found</td>
            </tr>
        <% } %>
    </tbody>
</table>

        </div>
    </div>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">