<% layout("/layouts/boilerplate") %>
<!-- sidebar + right panel -->
<style>
    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: #f8f9fa;
    }

    #sidebar {
        background-color: #1e1e1e;
        border-right: 1px solid #2c2c2c;
        height: 100vh;
    }

    #sidebar h2 {
        font-weight: bold;
        padding-top: 1rem;
        padding-left: 1rem;
        height: 1rem;
        margin-bottom: 30px;
        color: #fff;
    }
.nav-item a div{
    color: white;
}
    #sidebar ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    #sidebar .nav-link {
        display: flex;
        align-items: center;
        padding: 0.8rem 1rem;
        border-radius: 0.5rem;
        color: #ccc;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
    }

    #sidebar .nav-link:hover,
    #sidebar .nav-link.active {
        background-color: #2c5234;
        color: #fff;
    }

    #sidebar .nav-link i {
        margin-right: 10px;
    }

    /* Right panel */
    .main-content {
        flex-grow: 1;
        padding: 30px;
        background-color: #fff;
        min-height: 100vh;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-green {
        background-color: #2c5234;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
    }

    .filters {
        display: flex;
        gap: 15px;
        margin: 20px 0;
        align-items: center;
    }

    .filters input,
    .filters select {
        padding: 6px 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 8px;
        overflow: hidden;
    }

    table th,
    table td {
        padding: 12px;
        border-bottom: 1px solid #eee;
        text-align: left;
    }

    table th {
        background: #f1f1f1;
        font-weight: 600;
    }

    .edit-link {
        color: #2c5234;
        font-weight: bold;
        cursor: pointer;
    }
</style>

