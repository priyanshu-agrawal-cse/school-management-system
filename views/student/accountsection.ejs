<% layout("/layouts/boilerplate") %>

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: #f8f9fa;
    }

    #sidebar {
        background-color: #1e1e1e;
        border-right: 1px solid #2c2c2c;
        height: 100vh;
    }

    #sidebar h2 {
        font-weight: bold;
        padding-top: 1rem;
        padding-left: 1rem;
        height: 1rem;
        margin-bottom: 30px;
        color: #fff;
    }

    .nav-item a div {
        color: white;
    }

    #sidebar ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    #sidebar .nav-link {
        display: flex;
        align-items: center;
        padding: 0.8rem 1rem;
        border-radius: 0.5rem;
        color: #ccc;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
    }

    #sidebar .nav-link:hover,
    #sidebar .nav-link.active {
        background-color: #2c5234;
        color: #fff;
    }

    #sidebar .nav-link i {
        margin-right: 10px;
    }

    .main-content {
        flex-grow: 1;
        padding: 30px;
        background-color: #fff;
        min-height: 100vh;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-green {
        background-color: #2c5234;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
    }

    .form-section {
        max-width: 400px;
        margin-top: 30px;
    }

    .form-section input {
        padding: 10px;
        margin-bottom: 15px;
        border: 1px solid #ccc;
        border-radius: 6px;
        width: 100%;
        font-size: 14px;
    }

    .form-section h3 {
        margin-bottom: 10px;
    }

    .form-section p {
        margin-bottom: 20px;
        color: #555;
    }
</style>

<div class="d-flex">
    <!-- Sidebar -->
    <div id="sidebar" class="p-3" style="width: 18rem">
        <h2>Alter</h2>
        <ul class="nav flex-column mt-2">
            <li class="nav-item">
                <a href="/dashboard" class="nav-link">
                    <div><i class="bi bi-speedometer2"></i> Dashboard</div>
                </a>
            </li>
            <li class="nav-item">
                <a href="/viewStudent" class="nav-link">
                    <div><i class="bi bi-people"></i> Students</div>
                </a>
            </li>
            <li class="nav-item">
                <a href="/fees" class="nav-link">
                    <div><i class="bi bi-cash-stack"></i> Fees</div>
                </a>
            </li>
            <li class="nav-item">
                <a href="/account" class="nav-link active">
                    <div><i class="bi bi-person-circle"></i> Account Details</div>
                </a>
            </li>
          
            <li class="nav-item">
                <a href="/classes/add" class="nav-link">
                   <div>   <i class="bi bi-gear"></i> add classes </div> 
                </a>
            </li>>
             <li class="nav-item">
                <a href="/logout" class="nav-link">
                   <div>   <i class="bi bi-gear"></i> logout </div> 
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="top-bar">
            <div>
                <h2>Account Details</h2>
                <p>Manage your UPI Account and Details.</p>
            </div>
            <div>
                <strong>Mount Carmel School</strong>
            </div>
        </div>

        <!-- UPI Form -->
        <div class="form-section">
            <h3>UPI Account Form</h3>
            <p>Enter your UPI details below to save or update your account information.</p>
              <div style="margin-bottom: 15px;">
        <label><strong>Current UPI Transaction ID:</strong></label><br>
        <span style="display: inline-block; margin-top: 5px; padding: 10px; background: #f1f1f1; border-radius: 6px;">
            <%= school.upiId || "Not Set" %>
        </span>
    </div>

            <form action="/save-upi-details" method="POST">
                
                <input type="text" name="transactionId" placeholder="Enter Updated UPI Transaction ID" required>
                <button type="submit" class="btn-green">Save changes</button>
            </form>
        </div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">