<style>
  body {
    background: #f2f2f2;
    font-family: "Segoe UI", sans-serif;
  }

  .login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
  }

  .login-card {
    background: #fff;
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    width: 400px;
    text-align: center;
  }

  .login-card img {
    width: 70px;
    margin-bottom: 20px;
  }

  .login-card h2 {
    font-weight: bold;
    margin-bottom: 5px;
  }

  .login-card p {
    color: #888;
    font-size: 14px;
    margin-bottom: 25px;
  }

  .google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 10px;
    cursor: pointer;
    margin-bottom: 20px;
    font-size: 15px;
    font-weight: 500;
  }

  .google-btn img {
    width: 20px;
    margin-right: 10px;
  }

  .divider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 20px 0;
    color: #888;
    font-size: 14px;
  }

  .divider::before, .divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid #ddd;
  }

  .divider:not(:empty)::before {
    margin-right: .75em;
  }

  .divider:not(:empty)::after {
    margin-left: .75em;
  }

  .form-control {
    border-radius: 8px;
    padding: 12px;
    font-size: 15px;
  }

  .input-group-text {
    background: #fff;
    border-right: 0;
    color: #888;
  }

  .btn-green {
    background: #2c5234;
    color: #fff;
    border: none;
    width: 100%;
    padding: 12px;
    border-radius: 8px;
    font-size: 16px;
    margin-top: 10px;
  }

  .login-options {
    display: flex;
    justify-content: space-between;
    margin-top: 10px;
    font-size: 13px;
  }

  .login-options a {
    text-decoration: none;
    color: #2c5234;
  }

  .signup-text {
    margin-top: 15px;
    font-size: 14px;
  }

  .signup-text a {
    color: #2c5234;
    font-weight: 500;
    text-decoration: none;
  }
</style>

<div class="login-container">
  <div class="login-card">
    <!-- Back to Home -->
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;color:#2c5234;font-size:13px;font-weight:600;text-decoration:none;margin-bottom:16px;opacity:0.7;transition:opacity 0.2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.7">
      <i class="bi bi-arrow-left"></i> Back to Home
    </a>

    <!-- Logo Icon -->
    <div style="width:56px;height:56px;background:linear-gradient(135deg,#1a4731,#2c6e49);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 4px 14px rgba(26,71,49,0.3)">
      <i class="bi bi-mortarboard-fill" style="color:white;font-size:26px"></i>
    </div>

    <!-- Welcome -->
    <h2>Welcome Back</h2>
    <p>Sign in to your EduManage account</p>

    <!-- Google button -->
    <div class="google-btn">
      <img src="https://www.svgrepo.com/show/355037/google.svg" alt="Google"> 
      Continue with Google
    </div>

    <!-- Divider -->
    <div class="divider">or Continue with</div>

    <!-- Login form -->
    <form method="post" action="/login" novalidate class="needs-validation">
      <div class="mb-3 input-group">
        <span class="input-group-text"><i class="bi bi-person"></i></span>
        <input type="text" name="username" id="username" placeholder="Enter Username" class="form-control" required>
      </div>

      <div class="mb-3 input-group">
        <span class="input-group-text"><i class="bi bi-lock"></i></span>
        <input type="password" name="password" id="password" placeholder="Enter Password" class="form-control" required>
      </div>

      <div class="login-options">
        <label><input type="checkbox"> Remember me</label>
        <a href="#">Forgot your Password?</a>
      </div>

      <button type="submit" class="btn-green">Sign In</button>
    </form>

    <div class="signup-text">
      Don't have an account? <a href="/signup">Create one free</a>
    </div>
  </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
