<style>
  body {
    background: #f2f2f2;
    font-family: "Segoe UI", sans-serif;
  }

  .signup-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
  }

  .signup-card {
    background: #fff;
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    width: 400px;
    text-align: center;
  }

  .signup-card img {
    width: 70px;
    margin-bottom: 20px;
  }

  .signup-card h2 {
    font-weight: bold;
    margin-bottom: 5px;
  }

  .signup-card p {
    color: #888;
    font-size: 14px;
    margin-bottom: 25px;
  }

  .form-control {
    border-radius: 8px;
    padding: 12px;
    font-size: 15px;
  }

  .input-group-text {
    background: #fff;
    border-right: 0;
    color: #888;
  }

  .btn-green {
    background: #2c5234;
    color: #fff;
    border: none;
    width: 100%;
    padding: 12px;
    border-radius: 8px;
    font-size: 16px;
    margin-top: 10px;
    cursor: pointer;
  }

  .signup-text {
    margin-top: 15px;
    font-size: 14px;
  }

  .signup-text a {
    color: #2c5234;
    font-weight: 500;
    text-decoration: none;
  }
</style>

<div class="signup-container">
  <div class="signup-card">
    <!-- Back to Home -->
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;color:#2c5234;font-size:13px;font-weight:600;text-decoration:none;margin-bottom:16px;opacity:0.7;transition:opacity 0.2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.7">
      <i class="bi bi-arrow-left"></i> Back to Home
    </a>

    <!-- Logo Icon -->
    <div style="width:56px;height:56px;background:linear-gradient(135deg,#1a4731,#2c6e49);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 4px 14px rgba(26,71,49,0.3)">
      <i class="bi bi-mortarboard-fill" style="color:white;font-size:26px"></i>
    </div>

    <!-- Title -->
    <h2>Create Account</h2>
    <p>Start managing your school for free</p>

    <!-- Signup form -->
    <form method="post" action="/signup" novalidate class="needs-validation">
      <div class="mb-3 input-group">
        <span class="input-group-text"><i class="bi bi-person"></i></span>
        <input type="text" name="username" id="username" placeholder="Enter username" class="form-control" required>
      </div>

      <div class="mb-3 input-group">
        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
        <input type="email" name="email" id="email" placeholder="Enter email" class="form-control" required>
      </div>

      <div class="mb-3 input-group">
        <span class="input-group-text"><i class="bi bi-lock"></i></span>
        <input type="password" name="password" id="password" placeholder="Enter password" class="form-control" required>
      </div>

      <button type="submit" class="btn-green">Create Free Account</button>
    </form>

    <div class="signup-text">
      Already have an account? <a href="/login">Sign In</a>
    </div>
  </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
