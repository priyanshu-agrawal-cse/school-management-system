<% layout("/layouts/boilerplate") %>

<style>

.container{
    padding:20px;
}

/* CARD UI */

.card{
    background:white;
    padding:15px;
    margin-bottom:20px;
    border-radius:12px;
    box-shadow:0px 2px 6px rgba(0,0,0,0.1);
}

/* FORM */

input, textarea, select{
    width:100%;
    padding:8px;
    margin-bottom:10px;
    border-radius:6px;
    border:1px solid #ccc;
}

/* BUTTON */

.btn{
    background:#2c5234;
    color:white;
    border:none;
    padding:8px 15px;
    border-radius:6px;
    cursor:pointer;
}

/* STUDENT LIST */

.student-list{
    list-style:none;
    padding:0;
}

.student-list li{
    padding:5px 0;
    border-bottom:1px solid #eee;
}

/* HOMEWORK ITEM */

.hw-item{
    margin-bottom:10px;
}

</style>



<div class="container">

<h2>Welcome <%= teacher.name %></h2>

<p class="mb-4">
    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
        <i class="bi bi-person-workspace me-2"></i>Class Teacher: Class <%= teacher.classId.class %> - <%= teacher.classId.section %>
    </span>
</p>

<div class="mb-4">
    <a href="/attendance/mark/<%= teacher.classId._id %>" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
        <i class="bi bi-calendar-check me-2"></i>Mark Today's Attendance
    </a>
</div>


<!-- STUDENTS -->

<div class="card">

<h3>Students</h3>

<ul class="student-list">

<% students.forEach(s => { %>
<li><%= s.name %></li>
<% }) %>

</ul>

</div>



<!-- ADD HOMEWORK -->

<div class="card">

<h3>Add Homework</h3>

<form action="/teacher/add-homework/<%= teacher._id %>" method="POST">

<!-- SELECT CLASS -->

<select name="classId" required>

<option value="">Select Class</option>

<% classes.forEach(c => { %>

<option value="<%= c._id %>">
Class <%= c.class %> - <%= c.section %>
</option>

<% }) %>

</select>


<input type="text" name="subject" placeholder="Subject" required>

<textarea name="homework" placeholder="Write homework here..." required></textarea>

<input type="date" name="dueDate">

<button class="btn">Add Homework</button>

</form>

</div>



<!-- HOMEWORK LIST -->

<div class="card">

<h3>Homework Given</h3>

<% if(homeworks.length === 0){ %>

<p>No homework assigned yet</p>

<% } %>


<% homeworks.forEach(hw => { %>

<div class="hw-item">

<b><%= hw.subject %></b>  

<!-- SHOW CLASS -->
<% if(hw.classId){ %>
(Class <%= hw.classId.class %> - <%= hw.classId.section %>)
<% } %>

<br>

<%= hw.homework %>

<br>

<small>
Due: <%= hw.dueDate ? new Date(hw.dueDate).toDateString() : "N/A" %>
</small>

</div>

<hr>

<% }) %>

</div>


</div>