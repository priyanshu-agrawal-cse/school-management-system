<% layout("/layouts/schoolLayout") %>
<% var currentPage = 'addTeacher'; %>

<style>
  body { margin: 0; font-family: "Segoe UI", sans-serif; background: #f8f9fa; }
  .form-card { background: white; border: 1px solid #ddd; padding: 30px; border-radius: 10px; max-width: 680px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .form-card h2 { margin-top: 0; font-size: 20px; margin-bottom: 20px; }
  .form-group { margin-bottom: 16px; }
  .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; color: #374151; }
  .form-group input, .form-group select { width: 100%; padding: 10px 12px; border: 1px solid #ccc; border-radius: 8px; font-size: 14px; box-sizing: border-box; }
  .form-group input:focus, .form-group select:focus { outline: none; border-color: #2c5234; box-shadow: 0 0 0 3px rgba(44,82,52,0.1); }
  .btn-green { background: #2c5234; color: white; border: none; padding: 11px 24px; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; width: 100%; margin-top: 8px; }
  .btn-green:hover { background: #1a4731; }
  .top-bar { margin-bottom: 24px; }
  .top-bar h2 { margin: 0 0 4px; }
  .top-bar p { margin: 0; color: #6b7177; font-size: 14px; }
</style>

<div class="app-wrapper">
  <%- include("../includes/sideNav.ejs", {currentPage: 'addTeacher'}) %>

  <!-- Right Panel -->
  <div class="main-content">
    <div class="top-bar">
      <h2>Add Teacher</h2>
      <p>Register a new teacher and assign them to a class.</p>
    </div>

    <div class="form-card">
      <form action="/teachers/add" method="POST">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" placeholder="Enter teacher's full name" required>
        </div>
        <div class="form-group">
          <label>Phone Number</label>
          <input type="number" name="phoneNumber" placeholder="10-digit mobile number" required>
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" placeholder="teacher@school.com">
        </div>
        <div class="form-group">
          <label>Address</label>
          <input type="text" name="address" placeholder="Residential address">
        </div>
        <div class="form-group">
          <label>Monthly Salary (₹)</label>
          <input type="number" name="salary" placeholder="e.g. 25000" required>
        </div>
        <div class="form-group">
          <label>Subjects (comma separated)</label>
          <input type="text" name="subjects" placeholder="e.g. Math, Science, English">
        </div>
        <div class="form-group">
          <label>Class Teacher Of</label>
          <select name="classId">
            <option value="">Select a Class</option>
            <% classes.forEach(c => { %>
              <option value="<%= c._id %>">Class <%= c.class %> - <%= c.section %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn-green">Add Teacher</button>
      </form>
    </div>
  </div><!-- /main-content -->
</div><!-- /app-wrapper -->