<% layout("/layouts/schoolLayout") %>
<div class="app-wrapper">
    <%- include("../includes/sideNav.ejs", {currentPage: 'exams'}) %>
    <div class="main-content">
    <div class="header d-flex justify-content-between align-items-center">
        <div>
            <h2>Enter Marks</h2>
            <p><%= exam.name %> - Class <%= exam.classId.class %></p>
        </div>
    </div>

    <form action="/exams/marks/<%= exam._id %>" method="POST">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Roll No</th>
                            <th>Student</th>
                            <th style="width: 200px;">Marks for Math</th>
                            <th style="width: 200px;">Marks for Science</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let s of students) { %>
                            <tr>
                                <td class="ps-4 fw-bold text-muted"><%= s.rollNumber %></td>
                                <td>
                                    <div class="fw-semibold"><%= s.name %></div>
                                    <small class="text-muted"><%= s.father_name %></small>
                                </td>
                                <td>
                                    <input type="number" name="marks[<%= s._id %>][Maths]" class="form-control form-control-sm border-0 bg-light" placeholder="0-100">
                                </td>
                                <td>
                                    <input type="number" name="marks[<%= s._id %>][Science]" class="form-control form-control-sm border-0 bg-light" placeholder="0-100">
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm">Submit Marks</button>
        </div>
    </form>
</div>
</div>

