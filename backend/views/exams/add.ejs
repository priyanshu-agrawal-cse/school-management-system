<% layout("/layouts/schoolLayout") %>
<div class="app-wrapper">
    <%- include("../includes/sideNav.ejs", {currentPage: 'exams'}) %>
    <div class="main-content">
    <div class="header">
        <div>
            <h2>Schedule New Exam</h2>
            <p>Create a new examination event</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 mt-4">
                <form action="/exams/add" method="POST">
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Exam Name</label>
                        <input type="text" name="name" class="form-control p-3 bg-light border-0 rounded-3" placeholder="e.g. Mid-Term Examination" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Select Class</label>
                        <select name="classId" class="form-select p-3 bg-light border-0 rounded-3">
                            <% for(let cls of classes) { %>
                                <option value="<%= cls._id %>">Class <%= cls.class %> - <%= cls.section %></option>
                            <% } %>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Exam Date</label>
                        <input type="date" name="date" class="form-control p-3 bg-light border-0 rounded-3" required>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm">Schedule Exam</button>
                        <a href="/exams" class="btn btn-light px-4 rounded-pill">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

