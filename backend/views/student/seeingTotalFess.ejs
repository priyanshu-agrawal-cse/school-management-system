<% layout("/layouts/schoolLayout") %>
<% var currentPage = 'fees'; %>

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: #f8f9fa;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .btn-green {
        background-color: #2c5234;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
    }

    .filters {
        display: flex;
        gap: 15px;
        margin: 20px 0;
        align-items: center;
        flex-wrap: wrap;
    }

    .filters input,
    .filters select {
        padding: 6px 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    table th,
    table td {
        padding: 12px;
        border-bottom: 1px solid #eee;
        text-align: left;
        font-size: 14px;
    }

    table th {
        background: #f1f1f1;
        font-weight: 600;
    }

    .status-link {
        color: #2c5234;
        font-weight: bold;
        cursor: pointer;
    }
</style>

<div class="app-wrapper">
    <%- include("../includes/sideNav.ejs", {currentPage: 'fees'}) %>

    <!-- Right Panel -->
    <div class="main-content">
        <!-- Top bar -->
        <div class="top-bar">
            <div>
                <h2>Fees Management</h2>
                <p>Manage and monitor student fee payments.</p>
            </div>
            <form action="/verify-bank-statement" method="POST" enctype="multipart/form-data"
                style="display:flex; flex-direction:column; gap:10px; min-width:250px;">
                <label style="font-size: 13px; font-weight: 600;">Bank Statement Verification</label>
                <div class="d-flex gap-2">
                    <input type="file" name="bankStatement" id="fileUpload" accept=".pdf" class="form-control form-control-sm" required>
                    <button type="submit" class="btn-green">Verify</button>
                </div>
            </form>
        </div>

        <!-- Filters -->
        <div class="filters">
            <input type="text" placeholder="Search by Name">
            <select>
                <option>Type</option>
                <option>Days</option>
                <option>Months</option>
            </select>
            <select>
                <option>Class</option>
                <% school.classId.forEach(c=> { %>
                    <option value="<%= c._id %>">
                        <%= c.class %> (<%= c.section %>)
                    </option>
                    <% }) %>
            </select>
            <select>
                <option>Months</option>
                <option>June</option>
                <option>July</option>
            </select>
            <select>
                <option>Status</option>
                <option>Paid</option>
                <option>Pending</option>
            </select>
        </div>

        <!-- Table -->
        <table>
            <thead>
                <tr>
                    <th>S/N</th>
                    <th>Name</th>
                    <th>Class</th>
                    <th>Tran No</th>
                    <th>Amount</th>
                    <th>Date/Time</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% if (transactions && transactions.length > 0) { %>
                    <% transactions.forEach((t, index) => { %>
                        <tr>
                            <td><%= index + 1 %>.</td>
                            <td><%= t.studentId ? t.studentId.name : "N/A" %></td>
                            <td>
                                <% if (t.studentId && t.studentId.classId) { %>
                                    <%= t.studentId.classId.class %> (<%= t.studentId.classId.section %>)
                                <% } else { %>
                                    N/A
                                <% } %>
                            </td>
                            <td><%= t.UTR ? t.UTR : "Cash" %></td>
                            <td>₹ <%= t.amount %></td>
                            <td>
                                <% if (t.date) { %>
                                    <%= new Date(t.date).toLocaleDateString() %>
                                    <small class="text-muted text-sm"><%= new Date(t.date).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></small>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td>
                                <span class="status-link">
                                    <%= t.status || "Activate" %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align:center;">No transactions found</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div><!-- /main-content -->
</div><!-- /app-wrapper -->

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">