<% layout("/layouts/schoolLayout") %>

<style>

body{
    margin:0;
    font-family:"Segoe UI",sans-serif;
    background:#f8f9fa;
}


/* SIDEBAR */

#sidebar{
    background:#1e1e1e;
    height:100vh;
    border-right:1px solid #2c2c2c;
}

#sidebar h2{
    color:white;
}

.nav-item a div{
    color:white;
}

#sidebar .nav-link:hover,
#sidebar .nav-link.active{
    background:#2c5234;
}



/* RIGHT PANEL */

.main-content{
    flex-grow:1;
    padding:30px;
}


/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}


/* CARDS */

.dashboard-cards{
display:flex;
gap:20px;
margin-bottom:30px;
flex-wrap:wrap;
}

.card-box{

background:white;
padding:20px;
border-radius:10px;
width:220px;
box-shadow:0px 2px 6px rgba(0,0,0,0.1);

}

.card-box h3{
margin:0;
font-size:28px;
}

.card-box p{
margin:5px 0 0 0;
color:gray;
}



/* GRAPHS */

.dashboard-bottom{

display:flex;
gap:20px;
flex-wrap:wrap;

}


.graph-box{

background:white;
flex:2;
padding:20px;
border-radius:10px;
box-shadow:0px 2px 6px rgba(0,0,0,0.1);

}


.pie-box{

background:white;
flex:1;
padding:20px;
border-radius:10px;
box-shadow:0px 2px 6px rgba(0,0,0,0.1);

}


</style>



<div class="app-wrapper">
<%- include("../includes/sideNav.ejs", {currentPage: 'dashboard'}) %>



<!-- RIGHT DASHBOARD -->

<div class="main-content">



<div class="header">

<div>

<h2>Dashboard</h2>

<p>Monitor your members performance and analytics</p>

</div>

</div>



<!-- CARDS -->


<div class="dashboard-cards">



<div class="card-box">

<h3>

<%= totalStudents %>

</h3>

<p>Total Students</p>

</div>




<div class="card-box">

<h3>

<%= totalTransactions %>

</h3>

<p>Total Transactions</p>

</div>




<div class="card-box">

<h3>

Paid

</h3>

<p>Plan In Used</p>

</div>




<div class="card-box">

<h3>

₹ <%= totalFees %>

</h3>

<p>Total Fees This Month</p>

</div>



</div>




<!-- GRAPHS -->


<div class="dashboard-bottom">



<div class="graph-box">

<h4>Paid Fees Monthly</h4>

<canvas id="barChart"></canvas>

</div>




<div class="pie-box">

<h4>Fees Status</h4>

<canvas id="pieChart"></canvas>

</div>



</div>


</div><!-- /main-content -->
</div><!-- /app-wrapper -->




<!-- ICONS -->

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">




<!-- CHART JS -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>





    </div><!-- /main-content -->
</div><!-- /app-wrapper -->

<script>

/* Monthly data array */

const monthlyGraph = <%- JSON.stringify(monthlyGraph) %>;


/* BAR CHART */

new Chart(document.getElementById("barChart"),{

type:"bar",

data:{

labels:[
"Jan","Feb","Mar","Apr","May","Jun",
"Jul","Aug","Sep","Oct","Nov","Dec"
],

datasets:[{

label:"Fees",

data:monthlyGraph

}]

}

});


/* PIE CHART */

new Chart(document.getElementById("pieChart"),{

type:"doughnut",

data:{

labels:["Paid","Pending"],

datasets:[{

data:[
<%= paidCount %>,
<%= pendingCount %>
]

}]

}

});

</script>