<% layout("/layouts/schoolLayout") %>
<% var currentPage = 'account'; %>

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: #f8f9fa;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .btn-green {
        background-color: #2c5234;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
    }

    .form-section {
        max-width: 400px;
        margin-top: 30px;
    }

    .form-section input {
        padding: 10px;
        margin-bottom: 15px;
        border: 1px solid #ccc;
        border-radius: 6px;
        width: 100%;
        font-size: 14px;
    }

    .form-section h3 {
        margin-bottom: 10px;
    }

    .form-section p {
        margin-bottom: 20px;
        color: #555;
    }
</style>

<div class="app-wrapper">
    <%- include("../includes/sideNav.ejs", {currentPage: 'account'}) %>

    <!-- Main Content -->
    <div class="main-content">
        <div class="top-bar">
            <div>
                <h2>Account Details</h2>
                <p>Manage your UPI Account and Details.</p>
            </div>
            <div>
                <strong><%= school.schoolName %></strong>
            </div>
        </div>

        <!-- UPI Form -->
        <div class="form-section">
            <h3>UPI Account Form</h3>
            <p>Enter your UPI details below to save or update your account information.</p>
              <div style="margin-bottom: 15px;">
        <label><strong>Current UPI ID:</strong></label><br>
        <span style="display: inline-block; margin-top: 5px; padding: 10px; background: #e8f5e9; border: 1px solid #c8e6c9; border-radius: 6px; font-family: monospace; font-weight: bold; color: #2e7d32;">
            <%= school.upiId || "Not Set" %>
        </span>
    </div>

            <form action="/save-upi-details" method="POST">
                <label style="font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 5px; display: block;">Update UPI ID</label>
                <input type="text" name="transactionId" placeholder="e.g. school@upi" required>
                <button type="submit" class="btn-green">Save changes</button>
            </form>
        </div>
    </div><!-- /main-content -->
</div><!-- /app-wrapper -->

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">