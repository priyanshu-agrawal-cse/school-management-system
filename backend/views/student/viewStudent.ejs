<% layout("/layouts/schoolLayout") %>
<% var currentPage = 'students'; %>

<style>
  body { margin: 0; font-family: "Segoe UI", sans-serif; background: #f8f9fa; }
  .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .btn-green { background-color: #2c5234; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 14px; }
  .filters { display: flex; gap: 15px; margin: 20px 0; align-items: center; flex-wrap: wrap; }
  .filters input, .filters select { padding: 6px 10px; border: 1px solid #ccc; border-radius: 6px; }
  table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
  table th, table td { padding: 12px; border-bottom: 1px solid #eee; text-align: left; }
  table th { background: #f1f1f1; font-weight: 600; }
  .edit-link { color: #2c5234; font-weight: bold; cursor: pointer; }
</style>

<div class="app-wrapper">
  <%- include("../includes/sideNav.ejs", {currentPage: 'students'}) %>

  <!-- Right Panel -->
  <div class="main-content">
    <div class="top-bar">
      <div>
        <h2>Students</h2>
        <p>Monitor and manage your students.</p>
      </div>
      <button class="btn-green" onclick="window.location.href='/addStudent'">+ Add Student</button>
    </div>

    <!-- Filters -->
    <form method="GET" action="/viewStudent" class="filters">
      <input type="text" name="search" placeholder="Search by Name" value="<%= query?.search || '' %>">

      <select name="classId">
        <option value="">Select Class</option>
        <% for(let c of classes){ %>
          <option value="<%= c._id %>" <%= query?.classId == c._id.toString() ? "selected" : "" %>>
            <%= c.class %> <%= c.section %>
          </option>
        <% } %>
      </select>

      <select name="year">
        <option value="">Select Year</option>
        <option value="2025" <%= query?.year == "2025" ? "selected" : "" %>>2025</option>
        <option value="2024" <%= query?.year == "2024" ? "selected" : "" %>>2024</option>
      </select>

      <button type="submit" class="btn-green">Filter</button>
    </form>

    <!-- Table -->
    <table>
      <thead>
        <tr>
          <th>Roll No.</th>
          <th>Name</th>
          <th>Father's Name</th>
          <th>Mobile No.</th>
          <th>Class</th>
          <th>QR Code</th>
          <th>Edit</th>
        </tr>
      </thead>
      <tbody>
        <% for(let s of student) { %>
        <tr>
          <td><%= s.rollNumber %></td>
          <td><%= s.name %></td>
          <td><%= s.father_name %></td>
          <td><%= s.phoneNumber %></td>
          <td><%= s.classId.class %> <%= s.classId.section %></td>
          <td><i class="bi bi-qr-code"></i> <a href="/student/<%= s._id %>">Click here</a></td>
          <td><span class="edit-link">Edit</span></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div><!-- /main-content -->
</div><!-- /app-wrapper -->

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
