<% layout("/layouts/schoolLayout") %>
<div class="app-wrapper">
    <%- include("../includes/sideNav.ejs", {currentPage: 'attendance'}) %>
    <div class="main-content">
        <div class="header d-flex justify-content-between align-items-center">
            <div>
                <h2>Class Attendance Detail</h2>
                <p>Class <%= classDetail.class %> - <%= classDetail.section %> | <%= new Date(date).toDateString() %></p>
            </div>
            <a href="/attendance/report" class="btn btn-outline-primary rounded-pill btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back to Reports
            </a>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Roll No</th>
                            <th>Student Name</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let a of attendances) { %>
                            <tr>
                                <td class="ps-4 fw-bold text-muted"><%= a.studentId.rollNumber %></td>
                                <td>
                                    <div class="fw-semibold"><%= a.studentId.name %></div>
                                    <small class="text-muted"><%= a.studentId.father_name %></small>
                                </td>
                                <td class="text-center">
                                    <% if(a.status === 'Present') { %>
                                        <span class="badge bg-success rounded-pill px-3">Present</span>
                                    <% } else if(a.status === 'Absent') { %>
                                        <span class="badge bg-danger rounded-pill px-3">Absent</span>
                                    <% } else { %>
                                        <span class="badge bg-warning text-dark rounded-pill px-3">Leave</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
